# ══════════════════════════════════════════════════
# EconoBridge AI — 환경변수 템플릿
# .env.local에 복사 후 실제 키 입력
# ══════════════════════════════════════════════════

# ── Anthropic (필수) ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── 공공데이터포털 (data.go.kr) ──
# 장애인고용공단 + KOSHA 안전보건법령 공용
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# ── 고용24 OPEN-API (work24.go.kr) ──
# 채용정보 API (채용공고 검색)
WORK24_JOB_API_KEY=your_고용24_채용정보_key

# 직업정보 API (직업사전 검색)
WORK24_OCCUPATION_KEY=your_고용24_직업정보_key

# HRD-Net 훈련과정 API (대표키)
HRDNET_API_KEY=your_hrdnet_api_key_here

# HRD-Net 개별 서비스 (선택)
HRDNET_TRAINING_KEY=your_국민내일배움카드_key
HRDNET_EMPLOYER_KEY=your_사업주훈련_key
HRDNET_COMMON_CODE_KEY=your_공통코드_key
HRDNET_DUAL_KEY=your_일학습병행_key
HRDNET_CONSORTIUM_KEY=your_컨소시엄_key

# ── KOSHA 안전보건법령 ──
# data.go.kr 인증키 공용 (별도 불필요)
# 엔드포인트: https://apis.data.go.kr/B552468/srch/smartSearch
KOSHA_API_KEY=your_data_go_kr_api_key_here
